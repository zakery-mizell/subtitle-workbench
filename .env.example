CORS_ORIGIN=http://localhost:5173
WHISPER_CACHE_DIR=./models/whisper
DIARIZATION_AUTH_TOKEN=
DIARIZATION_MAX_DURATION_SECONDS=3600
LOW_CONFIDENCE_THRESHOLD=0.55
SILENCE_SECONDS=8
DEFAULT_LANGUAGE=

# Audio mastering (Auphonic-style local post production)
# Where processed masters are written before download.
MASTERING_OUTPUT_DIR=./tmp/mastering
# auto | cuda | mps | cpu
MASTERING_DEVICE=auto
# Finished mastering jobs and their files are purged after this many seconds.
MASTERING_JOB_TTL_SECONDS=14400
# Cache directory for downloaded AI models (MossFormer2 denoiser, etc.).
MODEL_CACHE_DIR=./models
